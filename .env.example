# Server
PORT=3333
NODE_ENV=development

# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require

# Auth
JWT_SECRET=change-me-in-production

# Comma-separated allowed frontend origins (no trailing slash)
# Production example:
# CORS_ORIGIN=https://tnt-news-front.vercel.app
CORS_ORIGIN=http://localhost:5173,https://tnt-news-front.vercel.app
